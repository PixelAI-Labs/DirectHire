# ============================================
# DirectHire Environment Configuration
# Copy to .env and fill in real values
# ============================================

# Backend
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# MongoDB
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/directhire?retryWrites=true&w=majority
MONGODB_DB_NAME=directhire

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# AI / Agents
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Email / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@directhire.io

# File Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Frontend URLs
CANDIDATE_APP_URL=http://localhost:5173
RECRUITER_APP_URL=http://localhost:5174
