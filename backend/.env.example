# App
APP_ENV=development
DEBUG=True
HOST=0.0.0.0
PORT=8000
SECRET_KEY=change-me-in-production

# MongoDB
MONGODB_URL=mongodb://localhost:27017/directhire
MONGODB_DB_NAME=directhire

# AI APIs
GEMMA_API_KEY=your_api_key_here
GEMMA_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMMA_E4B_MODEL=gemma-4-26b-a4b-it
GEMMA_MOE_MODEL=gemma-4-31b-it
GEMMA_DENSE_MODEL=gemma-4-31b-it

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-1.5-flash

NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_STT_URL=https://integrate.api.nvidia.com/v1/audio/transcriptions
NVIDIA_STT_MODEL=nvidia/whisper-large-v3

